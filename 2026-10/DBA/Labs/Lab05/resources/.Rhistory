library(ggplot2)
library(ggridges)
theme_set(theme_minimal())
grades <- data |> select(setup, backup, event, recovery, presentation) |>
pivot_longer(
cols = starts_with(""),
names_to = "criteria",
values_to = "score"
)
grades <- data |> select(setup, backup, event, recovery, presentation) |>
pivot_longer(
names_to = "criteria",
values_to = "score"
)
grades <- data |> select(setup, backup, event, recovery, presentation) |>
pivot_longer(
names_to = "criteria",
values_to = "score"
)
grades <- data |> select(setup, backup, event, recovery, presentation) |>
pivot_longer(
cols = c(setup, backup, event, recovery, presentation),
names_to = "criteria",
values_to = "score"
)
View(grades)
grades_longer <- data |> select(setup, backup, event, recovery, presentation) |>
pivot_longer(
cols = c(setup, backup, event, recovery, presentation),
names_to = "criteria",
values_to = "score"
)
ggplot(grades_longer, aes(x = score, y = criteria)) +
geom_density_ridges(scale = 0.6)
source("~/MEGA/Work/PUJ/2025-30/DBA/Labs/Lab05/resources/dba_midterm.R")
ggplot(
grades_longer,
aes(x = `Score`, y = `Rubric Criteria`, fill = stat(x))
) +
geom_density_ridges_gradient(scale = 3, size = 0.3, rel_min_height = 0.01) +
scale_fill_viridis_c(name = "Grade", option = "C") +
labs(title = 'Grades in DBA Midterm')
